# .env.example
# ═════════════
# This file is a TEMPLATE for environment variables.
# Copy it to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT RULES:
# 1. NEVER commit .env to Git — it contains secrets
# 2. ALWAYS commit .env.example — it shows what variables exist
# 3. .env is already in .gitignore

# API authentication key
# Change this to a strong random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=dev_key_change_in_production

# Environment name — used for logging
ENVIRONMENT=development

# Model artifacts path
MODELS_PATH=models/

# Dashboard API connection
# Local development:
API_URL=http://localhost:8000
# Inside Docker (use service name not localhost):
# API_URL=http://api:8000